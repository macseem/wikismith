# Database (Neon)
DATABASE_URL=postgresql://user:pass@host.neon.tech/wikismith?sslmode=require
DATABASE_URL_UNPOOLED=postgresql://user:pass@host.neon.tech/wikismith?sslmode=require

# WorkOS Auth
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
WORKOS_COOKIE_PASSWORD=
WORKOS_REDIRECT_URI=http://localhost:3000/api/auth/callback
# Keep NEXT_PUBLIC_WORKOS_REDIRECT_URI in sync with WORKOS_REDIRECT_URI.
NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://localhost:3000/api/auth/callback

# OpenAI
OPENAI_API_KEY=

# GitHub Webhooks
GITHUB_WEBHOOK_SECRET=

# Optional: required only if you want automatic GitHub token refresh
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# Encryption key for GitHub tokens (32 bytes hex)
TOKEN_ENCRYPTION_KEY=

# Daily wiki generation quota per authenticated user
DAILY_WIKI_GENERATION_LIMIT=5
